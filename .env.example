# Copy to .env and fill in for local development.
# Loaded via `set -a && source .env && set +a` before running the app,
# or exported directly in your shell / IDE run configuration.

DB_URL=jdbc:postgresql://localhost:5432/frilanceos
DB_USERNAME=frilanceos
DB_PASSWORD=frilanceos

# HS256 secret, base64-encoded, >= 32 bytes. Generate with:
#   openssl rand -base64 32
JWT_SECRET=change-me-to-a-real-base64-secret-before-any-real-use
JWT_ACCESS_TOKEN_TTL_MINUTES=1440